{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "declaration": true,
    "rootDir": "./src",
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "notix",
    "lib": ["DOM", "ES2022"]
  },
  "include": ["src", "demo.tsx"],
  "exclude": ["src/testing", "node_modules"]
}